<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>SEO Audit — 1drivemotors.co.uk</title>
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@600;700;800&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
<style>
*{box-sizing:border-box;margin:0;padding:0}
:root{
  --navy:#1B2A4A;--navy-mid:#243659;--accent:#2563EB;--accent-lt:#EFF6FF;
  --emerald:#10B981;--emerald-lt:#ECFDF5;--rose:#EF4444;--rose-lt:#FEF2F2;
  --amber:#F59E0B;--amber-lt:#FFFBEB;--border:#E2E8F0;
  --dark:#1E293B;--muted:#64748B;--bg:#EEF2F7;--white:#fff;
}
body{background:var(--bg);color:var(--dark);font-family:'Inter',sans-serif;font-size:14px;line-height:1.6}

/* TOPBAR */
.topbar{position:fixed;top:0;left:0;right:0;height:54px;background:var(--navy);z-index:200;display:flex;align-items:center;justify-content:space-between;padding:0 24px}
.tb-domain{font-family:'Syne',sans-serif;font-weight:700;font-size:15px;color:#fff}
.tb-centre{font-size:10px;text-transform:uppercase;letter-spacing:2px;color:#93C5FD;font-weight:500}
.tb-right{display:flex;gap:8px}
.tb-btn{font-size:11px;padding:5px 12px;border-radius:6px;border:1px solid rgba(255,255,255,.15);background:rgba(255,255,255,.06);color:#fff;cursor:pointer;font-family:'Inter',sans-serif;transition:background .2s}
.tb-btn:hover{background:rgba(255,255,255,.12)}
.tb-btn.active{background:rgba(37,99,235,.25);border-color:rgba(37,99,235,.5);color:#93C5FD}

/* HERO */
.hero{background:linear-gradient(160deg,#0a1628 0%,var(--navy-mid) 50%,#122240 100%);padding:86px 24px 48px;text-align:center;position:relative;overflow:hidden}
.hero::before{content:'';position:absolute;inset:0;background:radial-gradient(ellipse 60% 45% at 50% 0%,rgba(37,99,235,.1) 0%,transparent 70%);pointer-events:none}
.badge-row{display:flex;justify-content:center;gap:8px;margin-bottom:16px;flex-wrap:wrap}
.badge{display:inline-block;font-size:10px;letter-spacing:1.5px;text-transform:uppercase;padding:4px 12px;border-radius:20px;font-weight:600;font-family:'Inter',sans-serif}
.badge-blue{background:rgba(37,99,235,.2);color:#93C5FD;border:1px solid rgba(37,99,235,.3)}
.badge-amber{background:rgba(245,158,11,.2);color:#FCD34D;border:1px solid rgba(245,158,11,.3)}
.site-name{font-family:'Syne',sans-serif;font-weight:800;font-size:36px;color:#fff;margin-bottom:4px}
.sub-line{color:rgba(255,255,255,.45);font-size:12px;margin-bottom:36px}

/* GAUGES */
.gauge-trio{display:flex;justify-content:center;gap:36px;margin-bottom:32px;flex-wrap:wrap}
.gauge-wrap{text-align:center}
.gauge-lbl{font-size:10px;text-transform:uppercase;letter-spacing:1.5px;color:rgba(255,255,255,.45);margin-top:8px;font-weight:500}

/* HEALTH BAR */
.hbar-wrap{max-width:460px;margin:0 auto 32px}
.hbar-head{display:flex;justify-content:space-between;margin-bottom:6px}
.hbar-title{font-size:10px;text-transform:uppercase;letter-spacing:1.5px;color:rgba(255,255,255,.45);font-weight:500}
.hbar-pct{font-family:'Syne',sans-serif;font-size:17px;font-weight:800;color:#fff}
.hbar-track{height:6px;background:rgba(255,255,255,.08);border-radius:3px;overflow:hidden}
.hbar-fill{height:100%;border-radius:3px;background:linear-gradient(90deg,#EF4444 0%,#F59E0B 50%,#10B981 100%);width:0;transition:width 1.4s cubic-bezier(.4,0,.2,1)}
.radar-wrap{display:flex;justify-content:center}

/* SPA BANNER */
.spa-banner{background:#FFFBEB;border-bottom:2px solid #F59E0B;padding:12px 24px;text-align:center;font-size:12.5px;color:#92400E;line-height:1.55}
.spa-banner strong{color:#78350F}

/* SECTIONS */
.sec{max-width:880px;margin:0 auto;padding:40px 24px}
.sec-title{font-family:'Syne',sans-serif;font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:2px;color:var(--muted);margin-bottom:20px}

/* STRAT CARDS */
.strat-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(230px,1fr));gap:14px}
.sc{border-radius:12px;padding:20px;border:1px solid var(--border);background:var(--white);box-shadow:0 1px 3px rgba(0,0,0,.06),0 4px 16px rgba(0,0,0,.04)}
.sc.win{background:var(--emerald-lt);border-color:rgba(16,185,129,.25)}
.sc.risk{background:var(--rose-lt);border-color:rgba(239,68,68,.25)}
.sc.opp{background:var(--accent-lt);border-color:rgba(37,99,235,.25)}
.sc-icon{font-size:20px;margin-bottom:8px}
.sc-tag{font-size:9px;text-transform:uppercase;letter-spacing:1.5px;color:var(--muted);font-weight:600;margin-bottom:5px}
.sc-title{font-family:'Syne',sans-serif;font-size:13.5px;font-weight:700;color:var(--dark);margin-bottom:5px}
.sc-body{font-size:12px;color:var(--muted);line-height:1.55}

/* ACTION CARDS */
.action-cards{display:flex;flex-direction:column;gap:12px}
.ac{background:var(--white);border:1px solid var(--border);border-radius:12px;padding:18px 20px;display:grid;grid-template-columns:auto 1fr auto;gap:14px;align-items:start;border-left-width:3px;box-shadow:0 1px 3px rgba(0,0,0,.05)}
.ac-c{border-left-color:var(--rose)}
.ac-h{border-left-color:#F97316}
.ac-m{border-left-color:var(--amber)}
.ac-q{border-left-color:var(--emerald)}
.pill{font-size:9px;font-weight:700;text-transform:uppercase;letter-spacing:.8px;padding:3px 8px;border-radius:5px;white-space:nowrap;margin-top:2px}
.p-c{background:rgba(239,68,68,.1);color:#B91C1C;border:1px solid rgba(239,68,68,.2)}
.p-h{background:rgba(249,115,22,.1);color:#C2410C;border:1px solid rgba(249,115,22,.2)}
.p-m{background:rgba(245,158,11,.1);color:#92400E;border:1px solid rgba(245,158,11,.2)}
.p-q{background:rgba(16,185,129,.1);color:#065F46;border:1px solid rgba(16,185,129,.2)}
.ac-title{font-family:'Syne',sans-serif;font-size:13px;font-weight:700;color:var(--dark);margin-bottom:4px}
.ac-body{font-size:12px;color:var(--muted);line-height:1.55}
.tech{display:none;margin-top:10px;font-size:11.5px;color:var(--muted);background:var(--bg);border-radius:6px;padding:10px;line-height:1.6}
.ei-stack{display:flex;flex-direction:column;gap:7px;min-width:72px}
.ei-row{}
.ei-lbl{font-size:9px;text-transform:uppercase;letter-spacing:.8px;color:var(--muted);font-weight:500;margin-bottom:2px}
.ei-track{height:4px;background:var(--border);border-radius:2px;overflow:hidden}
.ei-fill{height:100%;border-radius:2px;width:0;transition:width 1.1s ease .3s}
.ef{background:var(--rose)}
.ei{background:var(--emerald)}

/* WINS */
.wins-wrap{background:var(--emerald-lt);border-top:1px solid rgba(16,185,129,.15);border-bottom:1px solid rgba(16,185,129,.15)}
.wins-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(210px,1fr));gap:12px}
.wc{background:rgba(16,185,129,.07);border:1px solid rgba(16,185,129,.18);border-radius:10px;padding:16px}
.wc-icon{font-size:16px;margin-bottom:5px}
.wc-title{font-family:'Syne',sans-serif;font-size:12.5px;font-weight:700;color:#065F46;margin-bottom:3px}
.wc-body{font-size:11.5px;color:#047857;line-height:1.5}

/* PAGES TABLE */
details{margin-bottom:10px}
details summary{list-style:none;cursor:pointer;padding:12px 16px;background:var(--white);border:1px solid var(--border);border-radius:10px;font-family:'Syne',sans-serif;font-size:12.5px;font-weight:700;color:var(--dark);display:flex;justify-content:space-between;align-items:center;transition:background .15s}
details summary:hover{background:var(--bg)}
details summary::after{content:'+';font-size:16px;color:var(--muted)}
details[open] summary::after{content:'−'}
details[open] summary{border-radius:10px 10px 0 0}
.det-body{padding:16px;background:var(--white);border:1px solid var(--border);border-top:none;border-radius:0 0 10px 10px;font-size:12px}
table{width:100%;border-collapse:collapse}
th{text-align:left;padding:7px 10px;font-size:10px;text-transform:uppercase;letter-spacing:.8px;color:var(--muted);font-weight:600;border-bottom:1px solid var(--border)}
td{padding:8px 10px;border-bottom:1px solid rgba(226,232,240,.5);color:var(--muted);vertical-align:top}
tr:last-child td{border-bottom:none}
.st{display:inline-block;font-size:9px;font-weight:700;text-transform:uppercase;padding:2px 6px;border-radius:4px;letter-spacing:.5px}
.st-ok{background:rgba(16,185,129,.1);color:#065F46}
.st-warn{background:rgba(245,158,11,.1);color:#92400E}
.st-bad{background:rgba(239,68,68,.1);color:#B91C1C}
.st-unk{background:rgba(100,116,139,.1);color:#475569}

.divider{border:none;border-top:1px solid var(--border)}
.footer{text-align:center;padding:24px;color:var(--muted);font-size:11px}

@media(max-width:600px){
  .gauge-trio{gap:18px}
  .site-name{font-size:26px}
  .ac{grid-template-columns:1fr;gap:10px}
  .tb-centre{display:none}
}
@media print{
  .topbar{display:none}
  body{background:#fff}
  .hero{margin-top:0;-webkit-print-color-adjust:exact;print-color-adjust:exact}
  .tech{display:block!important}
  details{display:block}
  details summary{display:none}
  .ac,.sc,.wc{page-break-inside:avoid;box-shadow:none}
}
</style>
</head>
